# ============================================================
# iM Bank 사업자 실영위 검증 시스템 - 환경 변수 설정 예시
# 실제 사용 시 이 파일을 .env 로 복사하고 값을 채워주세요.
# .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# 서버 설정
PORT=4000
NODE_ENV=development

# ── 공공데이터포털 API 키 (https://www.data.go.kr) ──────────────
# 국세청 사업자등록 진위확인 및 상태조회 서비스
NTS_API_KEY=your_nts_service_key_here

# 국민건강보험공단 사업장 가입자 정보 (국민연금 포함)
NHIS_API_KEY=your_nhis_service_key_here

# 소상공인시장진흥공단 상권정보 API
SBIZ_API_KEY=your_sbiz_service_key_here

# 네이버 지역 검색 API (상권정보 1차 교차검증)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# 행정안전부 지방행정인허가 (localdata.go.kr)
LOCALDATA_API_KEY=your_localdata_key_here

# 국토교통부 건축물대장 정보 서비스
MOLIT_API_KEY=your_molit_service_key_here

# 여신금융협회 카드매출 정보 (제휴 기관 전용)
CARD_SALES_API_KEY=your_card_sales_key_here

# 국세청 전자세금계산서 API
E_TAX_API_KEY=your_etax_key_here

# ── Mock 모드 설정 ───────────────────────────────────────────
# true: 실제 API 대신 Mock 데이터 사용 (개발/시연용)
# false: 실제 공공데이터 API 호출
USE_MOCK=true

# ── 보안 설정 ────────────────────────────────────────────────
# CORS 허용 출처 (프론트엔드 URL)
ALLOWED_ORIGIN=http://localhost:5173

# Rate Limiting (분당 최대 요청 수)
RATE_LIMIT_MAX=30
